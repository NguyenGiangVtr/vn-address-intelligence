# VN Address Intelligence - Environment Variables Template
# Copy this file to .env and fill in the values

# JWT đăng nhập API/UI (thời hạn access token, đơn vị phút). Mặc định nếu bỏ trống: 10080 (= 7 ngày).
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# JWT_SECRET_KEY=đổi-thành-chuỗi-bí-mật-dài-ngẫu-nhiên

# Parser: số địa chỉ corpus tối đa khi load/encode Siamese (PhoBERT/mGTE). Mặc định nếu bỏ trống: 100000.
# PARSER_CORPUS_MAX_ADDRESSES=100000

# mGTE (Alibaba-NLP/gte-multilingual-base): auto | cpu | cuda. VPS lỗi kiểu "index … out of bounds" khi load thử: cpu
# PARSER_MGTE_DEVICE=cpu

# Database Configuration
DB_HOST=your_db_host
DB_PORT=5432
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=vn_address_intelligence_db

# Old Database Configuration (for sync)
OLD_DB_HOST=old_db_host
OLD_DB_PORT=5432
OLD_DB_USER=old_db_user
OLD_DB_PASS=old_db_password
OLD_DB_NAME=old_db_name
# VPS Configuration
VPS_IP=your_vps_ip
VPS_USER=root

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# TTL mặc định (giây): 3600 = 1h, 86400 = 24h
REDIS_CACHE_TTL=3600
# Tắt cache nếu Redis không khả dụng (graceful degradation)
REDIS_ENABLED=true

# Hugging Face Hub (khuyến nghị — giới hạn tốc độ cao hơn, tải model ổn định hơn)
# Khi không có token, huggingface_hub có thể log: "unauthenticated requests".
# Tạo token Read tại: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NER token-classification (đường dẫn thư mục local hoặc id Hugging Face).
# Production pipeline: NER_MODEL_ID có ưu tiên cao nhất; nếu không đặt, dùng models/phobert-ner-vn khi tồn tại,
# nếu không có thì tải mặc định dathuynh1108/ner-address-electra-base-vn.
# NER_MODEL_ID=dathuynh1108/ner-address-electra-base-vn

# Kibana/Logstash Logging
KIBANA_LOG_ENABLED=false
KIBANA_LOG_HOST=localhost
KIBANA_LOG_PORT=5044
KIBANA_LOG_APP_NAME=vn-address-intelligence
